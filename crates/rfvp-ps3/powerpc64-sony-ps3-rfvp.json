{
  "abi": "elfv1",
  "arch": "powerpc64",
  "cpu": "ppc64",
  "crt-objects-fallback": "false",
  "data-layout": "E-m:e-Fi64-i64:64-i128:128-n32:64",
  "emit-debug-gdb-scripts": false,
  "features": "+hard-float",
  "linker": "ppu-gcc",
  "linker-flavor": "gcc",
  "llvm-abiname": "elfv1",
  "llvm-target": "powerpc64-unknown-none",
  "max-atomic-width": 64,
  "metadata": {
    "description": "rfvp PS3 PPU staticlib target for PSL1GHT final linking",
    "host_tools": false,
    "std": false,
    "tier": 3
  },
  "panic-strategy": "abort",
  "relocation-model": "static",
  "target-endian": "big",
  "target-pointer-width": 64
}
